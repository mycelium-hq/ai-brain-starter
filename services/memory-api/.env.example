# Bearer token required on every endpoint except /healthz.
# Generate a fresh value, do not reuse the example.
MEMORY_API_TOKEN=replace-with-a-long-random-string

# Path to the personal graph.json (NetworkX node-link format).
# This is what graphify writes for your personal vault.
GRAPH_JSON_PATH_PERSONAL=/absolute/path/to/personal/graph.json

# Path to the team graph.json. Map this to whatever team vault you sync from
# (an Obsidian team vault, a Drive shared vault, etc.). Leave unset if you
# only run a personal graph.
GRAPH_JSON_PATH_TEAM=/absolute/path/to/team/graph.json

# Port the uvicorn server binds to.
MEMORY_API_PORT=8765
