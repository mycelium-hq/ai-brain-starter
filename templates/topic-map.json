    "\\bstrateg", "\\bplan\\b", "\\bfocus\\b", "\\bnext step",
    "\\bpriorities\\b", "\\bopen loop", "\\bpending\\b",
    "\\bwhat should (i|we)\\b", "\\bhow (should|do) (i|we)\\b",
    "\\bwhere (am|are) (i|we)\\b",
    "\\brevenue\\b", "\\bclient\\b", "\\bproduct\\b",
    "\\bgoal\\b", "\\bproject\\b", "\\bdecision\\b", "\\bmeeting\\b"
  ],

  "topics": [
