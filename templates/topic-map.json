    {
      "name": "product-strategy",
      "triggers": ["product", "roadmap", "feature", "launch", "go-to-market", "gtm"],
      "files": [
        "🚀 Company/📋 Strategy/Product.md",
        "🚀 Company/📋 Strategy/Strategy Index.md"
      ]
    },
    {
      "name": "sales-pipeline",
      "triggers": ["sales", "pipeline", "client", "deal", "prospect", "outreach"],
