{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Decision frontmatter",
  "type": "object",
  "_comment": "Schema for files in ⚙️ Meta/Decisions/. Aggregator depends on these fields. Malformed YAML in any decision file silently breaks Decision Log.md rebuild.",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "const": "decision"
    },
    "decision_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}",
      "description": "ISO 8601 date when decision was made"
    },
    "creationDate": {
      "type": "string",
      "description": "ISO 8601 timestamp"
    },
    "worktree": {
      "type": "string",
      "description": "Worktree slug or 'main'"
    },
    "floor": {
      "oneOf": [
        {"type": "integer", "minimum": 1, "maximum": 34},
        {"type": "string", "minLength": 1}
      ],
      "description": "Floor framework level (numeric 1-34 or named, e.g. 'Peace')"
    },
    "stakes": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "speed": {
      "type": "string",
      "enum": ["instant", "fast", "deliberate", "slow"]
    },
    "outcome": {
      "type": ["string", "null"],
      "description": "Filled in once decision resolves; can be empty placeholder"
    },
    "pattern": {
      "type": ["string", "null"],
      "description": "Pattern tag for retrospective grouping"
    }
  },
  "additionalProperties": true
}
