{
  "language": "es",
  "_comment": "Spanish closing signals. Includes Colombian, Mexican, Argentine variants.",

  "explicit": [
    "^/(cerrar|terminar|bye|chao)\\b",
    "(?:^|\\s)/(cerrar|terminar|bye|chao)\\b"
  ],

  "high_confidence": [
    "^(ok(ay)?[,.\\s]+)?cha[ou]+\\b",
    "^(ok(ay)?[,.\\s]+)?cha[ou]+!*$",
    "\\bnos vemos\\b",
    "\\bhasta (luego|maĂąana|pronto|la prĂłxima)\\b",
    "\\bbuenas noches\\b",
    "\\bya (estĂĄ|estuvo|fue)\\b",
    "\\bya quedĂł\\b",
    "\\b(eso|esto) es todo\\b",
    "\\blisto[,.!\\s]*(gracias)?[!.\\s]*$",
    "\\bgracias,? (eso|esto) es todo\\b",
    "\\bnos hablamos\\b",
    "\\bme voy\\b",
    "\\bcerremos (acĂĄ|aquĂ­|esto|por (hoy|ahora))\\b",
    "\\bcerr(emos|ar|amos)\\s+(la\\s+|esta\\s+)?sesi[oĂł]n\\b",
    "\\b(termin(amos|emos)|listo)\\s+por\\s+(hoy|ahora)\\b",
    "\\bya\\s+termin(amos|ĂŠ)\\b",
    "\\btermin(emos|amos)\\s+(esto|aquĂ­|acĂĄ|por\\s+hoy)\\b",
    "\\bya\\s+estuvo\\s+(por\\s+(hoy|ahora))?\\b",
    "\\bya\\s+fue\\s+(por\\s+(hoy|ahora))\\b",
    "\\bhasta luego\\b",
    "^chao+[!.\\s]*$",
    "^bye+[!.\\s]*$",
    "^listo[!.\\s]*$",
    "^gracias[!.\\s]*$",
    "^muchas gracias[!.\\s]*$",
    "\\bdale,?\\s+chao\\b",
    "\\bok(ay)?,?\\s+chao\\b"
  ],

  "ambiguous": [
    "^ok(ay)?[!.\\s]*$",
    "^dale[!.\\s]*$",
    "^bueno[!.\\s]*$",
    "^perfecto[!.\\s]*$",
    "^genial[!.\\s]*$",
    "^suena bien[!.\\s]*$",
    "^va[!.\\s]*$"
  ],

  "emoji_only": [
    "^[\\s]*đ[\\s]*$",
    "^[\\s]*đ[\\s]*$",
    "^[\\s]*âď¸?[\\s]*$"
  ],

  "false_positive_guards": [
    {
      "_comment": "Don't match 'chao' or 'bye' inside quotes",
      "pattern": "[\"'`].*\\b(chao|bye|listo)\\b.*[\"'`]"
    },
    {
      "_comment": "Don't match 'listo para X' â user describing readiness, not closing",
      "pattern": "\\blisto\\s+para\\s+\\w+"
    },
    {
      "_comment": "Don't match 'listo el X' â user announcing completion of subtask",
      "pattern": "\\blisto\\s+(el|la|los|las)\\s+\\w+"
    },
    {
      "_comment": "Don't match 'ya estĂĄ + mĂĄs' â user wants to keep going",
      "pattern": "\\bya\\s+est(ĂĄ|a),?\\s+(ahora|sigamos|continuemos|quĂŠ sigue)\\b"
    },
    {
      "_comment": "Don't match 'ok dale + mĂĄs' transitions",
      "pattern": "^(ok(ay)?|dale)[,.\\s]+(sigue|sigamos|ahora|entonces|pasemos)\\b"
    },
    {
      "_comment": "Don't match meta-questions about close signals",
      "pattern": "\\b(quĂŠ|cĂłmo|por quĂŠ|cuĂĄndo|dĂłnde|quiĂŠn|define|explica|significa)\\b.{0,40}\\b(chao|chau|listo|gracias|tchau|bye)\\b"
    },
    {
      "_comment": "Don't match question-form prompts ending in '?'",
      "pattern": "\\b(chao|chau|listo|hasta luego|nos vemos|gracias)\\b[^?]*\\?\\s*$"
    }
  ]
}
