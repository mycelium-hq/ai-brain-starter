    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash '[VAULT_PATH]/⚙️ Meta/scripts/write-hook.sh'",
            "statusMessage": "Checking write triggers..."
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/ai-brain-starter/hooks/post-tool-use-learnings.py 2>/dev/null || echo '{\"continue\":true,\"suppressOutput\":true}'"
